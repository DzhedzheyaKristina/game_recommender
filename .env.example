# Path to the Steam Reviews CSV used by the baseline and optional LLM reranking.
STEAM_REVIEWS_CSV=data/raw/steam_reviews.csv

# Set this to a processed file when you want user-based steps to run on a subset.
# Example balanced subset:
# data/processed/reviews_clean_balanced_subset.csv
# Leave it empty to use the default full processed dataset:
# data/processed/reviews_clean.csv
ACTIVE_PROCESSED_REVIEWS=

# Use the dedicated pilot split file for tiny LLM/user-based pilots.
# The main evaluation split file remains available as the default.
USE_PILOT_SPLITS=false
PILOT_SPLITS_PATH=data/processed/user_evaluation_splits_pilot.jsonl
MAX_PILOT_SPLITS=10
FORCE_HOLDOUT_INTO_CANDIDATE_POOL=true

# Leave empty to use synthetic demo scenarios.
# Final thesis experiments should use manually reviewed scenarios instead.
SCENARIOS_FILE=data/scenarios/manual_scenarios_template.jsonl

# Baseline ranking does not need LLM credentials.
# LLM_PROVIDER selects the provider: openai, openrouter, gigachat, or mock.
# LLM_MODE defaults to real. Set LLM_MODE=mock only for local validation runs.
# LLM_RESPONSE_LANGUAGE controls the language of LLM explanations.
# Use ru for Russian explanations or en for English explanations.
# LLM_SELECT_MEANINGFUL_USERS prefers users whose holdout is inside the candidate pool.
LLM_PROVIDER=gigachat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_MODE=real
LLM_RESPONSE_LANGUAGE=ru
LLM_SELECT_MEANINGFUL_USERS=true

# GigaChat provider settings.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=true
GIGACHAT_CA_BUNDLE=
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

MAX_LLM_SCENARIOS=20
MAX_LLM_CANDIDATES=20
