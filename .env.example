# Путь к CSV Steam Reviews для baseline и опционального LLM-реранжирования.
STEAM_REVIEWS_CSV=data/raw/steam_reviews.csv

# Укажите processed-файл, если запускаются user-based шаги на подвыборке.
# Пример для balanced subset:
# data/processed/reviews_clean_balanced_subset.csv
# Оставьте пустым, чтобы использовать основной processed-файл:
# data/processed/reviews_clean.csv
ACTIVE_PROCESSED_REVIEWS=

# Для небольших user-based pilot-запусков используйте отдельный файл сплитов.
# Основной файл сплитов остаётся доступным по умолчанию.
USE_PILOT_SPLITS=false
PILOT_SPLITS_PATH=data/processed/user_evaluation_splits_pilot.jsonl
MAX_PILOT_SPLITS=10
FORCE_HOLDOUT_INTO_CANDIDATE_POOL=true

# Оставьте пустым, чтобы использовать синтетические demo-сценарии.
# Для итоговых сценарных экспериментов предпочтительны вручную подготовленные сценарии.
SCENARIOS_FILE=data/scenarios/manual_scenarios_template.jsonl

# Baseline не требует LLM-учётных данных.
# LLM_PROVIDER: openai, openrouter, gigachat или mock.
# LLM_MODE по умолчанию real. Значение mock используйте только для локальной валидации.
# LLM_RESPONSE_LANGUAGE задаёт язык объяснений LLM.
# LLM_SELECT_MEANINGFUL_USERS отдаёт приоритет пользователям, у которых holdout уже есть в candidate pool.
LLM_PROVIDER=gigachat
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
LLM_MODE=real
LLM_RESPONSE_LANGUAGE=ru
LLM_SELECT_MEANINGFUL_USERS=true

# Настройки провайдера GigaChat.
GIGACHAT_AUTH_KEY=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat
GIGACHAT_VERIFY_SSL=true
GIGACHAT_CA_BUNDLE=
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_API_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

MAX_LLM_SCENARIOS=20
MAX_LLM_CANDIDATES=20
